## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Build results
bin/
obj/

# User-specific VS config
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio cache/options directory
.vs/

# Rider IDE folder
.idea/

# ASP.NET scaffolding
ScaffoldingReadMe.txt

# NuGet packages
*.nupkg
packages/
*.snupkg

# Logs
*.log

# Publish output
pub/
publish/
